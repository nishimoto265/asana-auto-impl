ASANA_PAT=
ASANA_WORKSPACE_GID=
ASANA_PROJECT_GID=
ASANA_POLL_INTERVAL_SEC=10
REPO_PATH=~/project
CLAUDE_CMD=claude
LOG_DIR=./logs
TMP_DIR=./tmp
CLONE_REPOS=https://github.com/everytv/delish-server,https://github.com/everytv/delish-web2,https://github.com/everytv/delish-dashboard2
NPM_INSTALL_DIRS=delish-web2,delish-dashboard2
DEBUG_ZIP_PATH=~/Downloads/debug.zip
DEBUG_ZIP_DEST=delish-server
CLAUDE_STARTUP_CMD=/mai
CLAUDE_STARTUP_WAIT=8
SHELL_CMD="zsh -l"
